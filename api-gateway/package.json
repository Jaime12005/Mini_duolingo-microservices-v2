{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for Duolingo microservices platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^2.0.6",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
